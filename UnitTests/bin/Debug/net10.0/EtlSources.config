<?xml version="1.0" encoding="utf-8" ?>

<etlSourcesSection>
	<etlSourceCollection>

		<!--
    
    Put ETL source elements here
    ============================
	      
    'streamid' is required from build #1.0.510 upwards.
    It is a string that describes this ETL source.  It can be anything, but it should describe what this ETL channel does (because it is used for logging) 
    and it must be unique with respect to the other ETL sources. 
  
    'ontology' is required.  It specifies how the data is transformed into the destination format.
    
    'url' is required.  It specifies the source of the data.
  
    'type' is required.  It specifies how the data arrives - xml, json or owl file drop or webservice. 
    It must be one of:    
    webservice,
    xmlfile,
    jsonfile,
    owlfile,

    'schema' is required.  It specifies the format of the source data.
    It must be one of: 
    smt,
    stats,
    ngss,
    optaf01,
    optaf40,
    ipvxmlv1,
    sportradarV1,
    warnermedia,
	ipvskosxmlv1
    
    'sequence' is optional.  It determines whether or not XML files are required to arrive in a strict sequence according to a timestamp in the content.
    It can have values:
    on (default),
    off

    NGSS Leagues

    leagueCode, leagueName, leagueAbbrev

    "00", "National Basketball Association", "NBA"
    "10", "Women's National Basketball Association", "WNBA"
    "15", "NBA Summer League","VSL"
    "20", "NBA G League","G League"
    "99", "NGSS Test League","NGSSTest"

	
    example

    <etlSource streamid="my first source" type="xmlfile" url="<path to file>" ontology="http://teragator.com/ns/ontology/something#" schema="stats" />
    <etlSource streamid="my second source" type="webservice" url="<URL of webservice>" ontology="http://teragator.com/ns/ontology/somethingelse#" schema="smt" />
	
	
	
	Service-specific examples
	=========================
	
	OptaSportsSoccer
	
    - 'streamid' describes this ETL source and it must be unique with respect to the other ETL sources. 
	
    - 'type' must be "webservicemulti".  This means the feed is accessed multiple times by an algorithm that picks out the correct data.
	
	- 'url' is the soccer endpoint and currently must be set to "https://api.performfeeds.com/soccerdata".
	
	- 'ontology' must be set to "http://teragator.com/ns/ontology/etl/generic/teamsportroster-2.0#".
	
	- 'schema' must be set to "optaSportsDataSoccer".  This is the format of the feed data.
	
	- 'key' must be set to the Outlet Authentication Key - a unique 26-character alphanumeric UUID which is unique to each outlet.
	
	- 'options' is a list of semi-colon-separated name-value pairs of the form "<name1>:<value1>; <name2>:<value2>; .. ;"
	
	  For OptaSportsDataSoccer the available name-value pairs are "competitions:<comma-separated list of competitions> OR *, and window:<-ve or 0 int, positive int>".
	  
	  The available competitions as of 11/10/2023 are:
	  "EFL Trophy", "FA Cup", "FA Women's League Cup", "League Cup", "Premier League", "Premier League 2 Division Two", "U18 Premier League", "U18 Premier League Cup", "Women's FA Cup", "Women's Super League", "UEFA Europa League".
	  The wildcard symbol * can also be used to select all possible competitions.  This is for testing only.  For deployment at customer sites only those competitions which are required shoud be listed.  
	  
	  The window determines which games are asked for in the request, by their start date.  The first number is an integer that specifies how long in days to look before the current date, and can be a negative integer or zero.
	  The second number is an integer that specifies how long in days to look after the current date, and must be a positive integer.  The numbers should be chosen so that only that data that is needed is ingested, otherwise,
	  unusable data might be ingested that causes the database to bloat.
	  
	  The following example line of configuration ingests the Premier League and League Cup games for the previous and upcoming 7 days.	  
      <etlSource streamid="Stream 1 OptaSportsSoccer webservice test" type="webservicemulti" url="https://api.performfeeds.com/soccerdata" ontology="http://teragator.com/ns/ontology/etl/generic/teamsportroster-2.0#" schema="optaSportsDataSoccer"  key="<Outlet Authentication Key>"  options="competitions:Premier League, League Cup; window:-7, 7" />
	  
	  This line ingests games for all available competitions for the next 28 days.	
	  <etlSource streamid="Stream 1 OptaSportsSoccer webservice test" type="webservicemulti" url="https://api.performfeeds.com/soccerdata" ontology="http://teragator.com/ns/ontology/etl/generic/teamsportroster-2.0#" schema="optaSportsDataSoccer"  key="<Outlet Authentication Key>"  options="competitions:*; window:0, 28" />
	  

	-->

	<!--Put lines of configuration here-->

		<!--Sportradar basketball-->
		<etlSource streamid="Stream 1 Full ETL test - Sportradar Basketball to Generic Multi Team Sports Roster" type="xmlfile" url="C:\Projects\Testing\Watchfolder\NBA_ROSTERS.XML" ontology="http://teragator.com/ns/ontology/etl/generic/teamsportroster-2.0#" schema="sportradarrosterV1" />
		<etlSource streamid="Stream 2 Full ETL test - Sportradar Basketball to Generic Multi Team Sports Schedule" type="xmlfile" url="C:\Projects\Testing\Watchfolder\NBA_SCHEDULE.XML" ontology="http://teragator.com/ns/ontology/etl/generic/teamsportdailyschedule-2.0#" schema="sportradarleaguescheduleV1" />

		<!--Sportradar hockey-->
		<etlSource streamid="Stream 3 Full ETL test - Sportradar Hockey to Generic Multi Team Sports Roster" type="xmlfile" url="C:\Projects\Testing\Watchfolder\NHL_ROSTERS.XML" ontology="http://teragator.com/ns/ontology/etl/generic/teamsportroster-2.0#" schema="sportradarrosterV1" />
		<etlSource streamid="Stream 4 Full ETL test - Sportradar Hockey to Generic Multi Team Sports Schedule" type="xmlfile" url="C:\Projects\Testing\Watchfolder\NHL_SCHEDULE.XML" ontology="http://teragator.com/ns/ontology/etl/generic/teamsportdailyschedule-2.0#" schema="sportradarleaguescheduleV1" />

		<!--Sportradar soccer-->
		<etlSource streamid="Stream 5 Full ETL test - Sportradar Soccer to Generic Multi Team Sports Roster" type="xmlfile" url="C:\Projects\Testing\Watchfolder\MLS_ROSTERS.XML" ontology="http://teragator.com/ns/ontology/etl/generic/teamsportroster-2.0#" schema="sportradarrosterV1" />
		<etlSource streamid="Stream 6 Full ETL test - Sportradar Soccer to Generic Multi Team Sports Schedule" type="xmlfile" url="C:\Projects\Testing\Watchfolder\MLS_SCHEDULE.XML" ontology="http://teragator.com/ns/ontology/etl/generic/teamsportdailyschedule-2.0#" schema="sportradarseasoncheduleV1" />

		<!-- Man U Opta Sports Soccer from JSON files. OT2 gets competition ids, MA1 gets schedules and rosters for competitions in time window -->
		<etlSource streamid="Stream 7 Full ETL test - OptaSportsSoccer Json file test" type="jsonfilemulti" url="C:\Projects\Testing\Watchfolder\OptaSportsDataSoccer" ontology="http://teragator.com/ns/ontology/etl/generic/teamsportroster-2.0#" schema="optaSportsDataSoccer"  key="xnfo53cm9i1p19zdg0462etrb" options="competitions:English Premier League, FA Women's League Cup; window:-14, 7" />

		<!-- OR Media Geo SKOS -->
		<etlSource streamid="Stream 8 Full ETL test - OR Media Geo SKOS" type="xmlfile" url="C:\Projects\Testing\Watchfolder\Skos\Geo.xml" ontology="http://teragator.com/ns/ontology/etl/cv/skos-1.0#" schema="ipvskosxmlv1"/>

		<!-- OR Media Contributors Interviewees SKOS -->
		<etlSource streamid="Stream 9 Full ETL test - OR Media Contributors Interviewees SKOS" type="xmlfile" url="C:\Projects\Testing\Watchfolder\Skos\SKOS Contributors Interviewees.xml" ontology="http://teragator.com/ns/ontology/etl/cv/skos-1.0#" schema="ipvskosxmlv1"/>

		<!-- Car and computer SKOS -->
		<etlSource streamid="Stream 10 Full ETL test - Car and computer SKOS" type="xmlfile" url="C:\Projects\Testing\Watchfolder\Skos\CarAndComputerTest.xml" ontology="http://teragator.com/ns/ontology/etl/cv/skos-1.0#" schema="ipvskosxmlv1"/>

		<!-- Special character car and computer SKOS -->
		<etlSource streamid="Stream 11 Full ETL test - Special character car and computer SKOS" type="xmlfile" url="C:\Projects\Testing\Watchfolder\Skos\SpecialCharacterTest.xml" ontology="http://teragator.com/ns/ontology/etl/cv/skos-1.0#" schema="ipvskosxmlv1"/>

		<!-- Woodland Trust SKOS -->
		<etlSource streamid="Stream 12 Full ETL test - Woodland Trust SKOS" type="xmlfile" url="C:\Projects\Testing\Watchfolder\Skos\Woodland Trust.xml" ontology="http://teragator.com/ns/ontology/etl/cv/skos-1.0#" schema="ipvskosxmlv1"/>
			

	</etlSourceCollection>
</etlSourcesSection>
